{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/target",
      "!**/.basalt",
      "!**/reference",
      "!**/tests/parity/baseline",
      "!**/tests/parity/fixtures",
      "!**/bun.lockb",
      "!**/*.lock",
      "!**/main.js",
      "!**/.venv*",
      "!packages/obsidian-plugin/main.js",
      "!**/*.css",
      "!**/*.astro",
      "!**/*.mdx",
      "!**/openapi.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "noDefaultExport": "error",
        "useImportType": "error",
        "useExportType": "error",
        "noNonNullAssertion": "off",
        "useTemplate": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "json": {
    "formatter": {
      "indentWidth": 2
    }
  },
  "overrides": [
    {
      "includes": ["**/packages/*/package.json", "**/package.json"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/vitest.config.ts",
        "**/vite.config.ts",
        "**/vitest.workspace.ts",
        "**/astro.config.*",
        "**/tailwind.config.*",
        "**/packages/obsidian-plugin/src/main.ts",
        "**/packages/api/src/index.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.test.ts", "**/__tests__/**", "**/tests/**"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/packages/{web,desktop,site,docs}/**/*.tsx",
        "**/packages/{web,desktop,site,docs}/**/pages/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
