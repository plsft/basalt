{
  "name": "basalt",
  "version": "1.2.0",
  "private": true,
  "description": "Basalt — a second-brain compiler that reads your Markdown vault and surfaces what you believe but never wrote down.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plsft/basalt.git"
  },
  "homepage": "https://virtuosoai.dev/basalt/",
  "engines": {
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "ci": "biome ci .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "bun bench/index-throughput.ts && bun bench/cold-start.ts && bun bench/idle-memory.ts",
    "bench:index": "bun bench/index-throughput.ts",
    "bench:cold-start": "bun bench/cold-start.ts",
    "bench:idle-memory": "bun bench/idle-memory.ts",
    "openapi": "bun scripts/generate-openapi.ts",
    "rehearse:plugin": "rh run .github/workflows/release-obsidian-plugin.yml",
    "rehearse:cli-mcp": "rh run .github/workflows/release-cli-mcp.yml",
    "rehearse:desktop": "rh run .github/workflows/release-desktop.yml",
    "rehearse:deploy-api": "rh run .github/workflows/deploy-api.yml",
    "rehearse:deploy-site": "rh run .github/workflows/deploy-site.yml",
    "rehearse:deploy-docs": "rh run .github/workflows/deploy-docs.yml",
    "rehearse:fast": "rh run .github/workflows/release-obsidian-plugin.yml && rh run .github/workflows/release-cli-mcp.yml",
    "rehearse:audit": "for wf in release-cli-mcp release-desktop release-obsidian-plugin; do rh compat .github/workflows/$wf.yml; done",
    "rehearse:hook": "rh install-hook .github/workflows/release-obsidian-plugin.yml"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rehearse/cli": "^0.6.19",
    "@types/node": "^25.6.2",
    "archiver": "^8.0.0",
    "typescript": "5.7.2",
    "vitest": "^4.1.5"
  }
}
