{
  "name": "basalt",
  "version": "0.0.0",
  "private": true,
  "description": "Basalt — a second-brain compiler that reads your Markdown vault and surfaces what you believe but never wrote down.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/plsft/basalt.git"
  },
  "homepage": "https://virtuosoai.dev/basalt/",
  "engines": {
    "bun": "1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "ci": "biome ci .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "test": "echo \"no tests yet — vitest lands in TASK-0.5\" && exit 0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "typescript": "5.7.2"
  }
}
