{
  "name": "basalted-mcp",
  "version": "0.0.0",
  "description": "Model Context Protocol server for Basalt. Exposes Brief, the five verbs, and audit as MCP tools so Claude Desktop / Cursor / Cline / Zed / VS Code Copilot can run them against your Markdown vault.",
  "license": "MIT",
  "homepage": "https://basalted.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plsft/basalt.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/plsft/basalt/issues"
  },
  "keywords": [
    "basalt",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-desktop",
    "cursor",
    "second-brain",
    "obsidian",
    "markdown"
  ],
  "type": "module",
  "bin": {
    "basalt-mcp": "./bin/basalt-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "bun build src/index.ts --compile --target=bun --outfile=bin/basalt-mcp",
    "compile:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=bin/basalt-mcp-linux-x64",
    "compile:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile=bin/basalt-mcp-linux-arm64",
    "compile:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=bin/basalt-mcp-darwin-x64",
    "compile:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=bin/basalt-mcp-darwin-arm64",
    "compile:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=bin/basalt-mcp-windows-x64.exe",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"basalted-mcp: tests run from root via 'bun run test'\" && exit 0",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "basalted": "workspace:*",
    "basalted-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^14.0.0",
    "zod": "^3.24.0"
  }
}
