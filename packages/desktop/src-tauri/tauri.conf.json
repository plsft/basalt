{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Basalt",
  "version": "0.0.0",
  "identifier": "com.plsft.basalt.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Basalt",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Visible",
        "transparent": false,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self' 'unsafe-eval'; connect-src 'self' http://localhost:11434 http://127.0.0.1:11434 ipc://localhost http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "© 2026 1556 Ventures LLC",
    "homepage": "https://virtuosoai.dev/basalt/",
    "publisher": "1556 Ventures LLC",
    "shortDescription": "Reads your vault and surfaces what you believe but never wrote down.",
    "longDescription": "Basalt is a local-first, read-only-by-default second-brain compiler. It reads a folder of Markdown — Obsidian vault, Logseq graph, plain ~/notes — and produces a weekly Brief about you, with citation-grounded findings across five named verbs.",
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": null,
      "entitlements": null,
      "providerShortName": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "",
      "endpoints": [
        "https://basalt-releases.plsft.com/updater/{{target}}/{{arch}}/{{current_version}}"
      ]
    },
    "fs": {
      "scope": {
        "allow": ["$HOME/**"],
        "deny": ["$HOME/.basalt/secrets/**"]
      }
    }
  }
}
