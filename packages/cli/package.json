{
  "name": "basalted",
  "version": "0.0.0",
  "description": "Basalt CLI — index, brief, audit your Markdown vault from the terminal.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "basalt": "./bin/basalt.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "bun build src/index.ts --compile --target=bun --outfile=bin/basalt",
    "compile:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile=bin/basalt-linux-x64",
    "compile:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile=bin/basalt-linux-arm64",
    "compile:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile=bin/basalt-darwin-x64",
    "compile:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile=bin/basalt-darwin-arm64",
    "compile:windows-x64": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile=bin/basalt-windows-x64.exe",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "echo \"basalted: tests run from root via 'bun run test'\" && exit 0",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "basalted-core": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^7.3.0",
    "commander": "^14.0.0",
    "env-paths": "^3.0.0",
    "kleur": "^4.1.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/bun": "^1.3.13"
  }
}
